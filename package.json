{
  "name": "all2api-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "node scripts/dev-electron.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "build:desktop": "npm run build && electron-builder",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "pinia": "^2.3.1",
    "playwright": "^1.59.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.12",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.proxyforge.desktop",
    "productName": "ProxyForge",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
